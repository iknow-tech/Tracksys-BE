<SofEnvelope>
    <sessionID>{sessionId}</sessionID>
    <action>execute</action>
    <data>
        <MWSBulkAttributeUpdate>
            <MWSObject>
                <id>{vehicleOrderItemId}</id>
                <sroid>{sroid}</sroid>
                <Field_Set>
                    <Field>
                        <id>{fieldId}</id>
                        <name></name>
                        <MWSMCurrencyValue>
                            <refAmount>{refAmount}</refAmount>
                            <curAmount>{curAmount}</curAmount>
                            <currencyId>{currencyId}</currencyId>
                        </MWSMCurrencyValue>
                    </Field>
                </Field_Set>
            </MWSObject>
        </MWSBulkAttributeUpdate>
    </data>
</SofEnvelope>
