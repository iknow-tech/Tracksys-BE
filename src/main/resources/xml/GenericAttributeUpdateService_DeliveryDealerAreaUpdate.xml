<SofEnvelope>
    <sessionID>{sessionId}</sessionID>
    <action>execute</action>
    <data>
        <MWSBulkAttributeUpdate>
            <MWSObject>
                <id>{contractId}</id> -- Kontrat id
                <sroid>{orderId}</sroid>  -- sabit Contract Objesi
                <Field_Set>
                    <Field>
                        <id>{fieldId}</id> -- sabit Alan id
                        <name></name>
                        <MWSStringValue>
                            <value>{value}</value>  -- Alanın güncelleneceği değer
                        </MWSStringValue>
                    </Field>
                </Field_Set>
            </MWSObject>
        </MWSBulkAttributeUpdate>
    </data>
</SofEnvelope>