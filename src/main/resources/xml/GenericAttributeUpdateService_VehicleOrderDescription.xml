<SofEnvelope>
    <sessionID>{sessionId}</sessionID>
    <action>execute</action>
    <data>
        <MWSBulkAttributeUpdate>
            <MWSObject>
                <id>{vehicleOrderId}</id> -- Vehicle_orderId
                <sroid>{orderId}</sroid>  ----- sabit  Order Objesi
                <Field_Set>
                    <Field>
                        <id>{id}</id> ----- sabit Alan id
                        <name></name>
                        <MWSStringValue>
                            <value>{value}</value> // Alanın güncelleneceği değer
                        </MWSStringValue>
                    </Field>
                </Field_Set>
            </MWSObject>
        </MWSBulkAttributeUpdate>
    </data>
</SofEnvelope>